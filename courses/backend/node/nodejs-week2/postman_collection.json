{
  "info": {
    "name": "Snippets API Collection",
    "description": "Postman collection for testing the Snippets API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Get All Snippets",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/snippets",
          "host": ["{{base_url}}"],
          "path": ["api", "snippets"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response has data array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Sorted Snippets",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/snippets/unsafe?sort=title%20DESC",
          "host": ["{{base_url}}"],
          "path": ["api", "snippets", "unsafe"],
          "query": [
            {
              "key": "sort",
              "value": "title DESC"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response has data field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Public Snippets",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/snippets/public",
          "host": ["{{base_url}}"],
          "path": ["api", "snippets", "public"]
        }
      }
    },
    {
      "name": "Get Snippets by Tag",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/snippets/tag/javascript",
          "host": ["{{base_url}}"],
          "path": ["api", "snippets", "tag", "javascript"]
        }
      }
    },
    {
      "name": "Get Snippet by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/snippets/1",
          "host": ["{{base_url}}"],
          "path": ["api", "snippets", "2"]
        }
      }
    },
    {
      "name": "Create New Snippet",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"title\": \"Test Snippet\",\n    \"contents\": \"console.log('Hello World');\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/snippets",
          "host": ["{{base_url}}"],
          "path": ["api", "snippets"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response has title\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('title');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update Snippet",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"title\": \"Updated Title\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/snippets/1",
          "host": ["{{base_url}}"],
          "path": ["api", "snippets", "1"]
        }
      }
    },
    {
      "name": "Delete Snippet",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/snippets/1",
          "host": ["{{base_url}}"],
          "path": ["api", "snippets", "1"]
        }
      }
    }
  ]
}